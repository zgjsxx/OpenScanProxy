{
  "proxy_listen_host": "0.0.0.0",
  "proxy_listen_port": 8080,
  "admin_listen_host": "127.0.0.1",
  "admin_listen_port": 9090,
  "admin_static_dir": "./web/dist",
  "ca_cert_path": "./certs/ca.crt",
  "ca_key_path": "./certs/ca.key",
  "enable_https_mitm": false,
  "scan_upload": true,
  "scan_download": true,
  "max_scan_file_size": 5242880,
  "allowed_mime": ["application/pdf", "application/zip", "application/octet-stream"],
  "allowed_extensions": ["pdf", "zip", "exe", "doc", "docx"],
  "scan_timeout_ms": 5000,
  "policy_mode": "fail-open",
  "suspicious_action": "log",
  "domain_whitelist": [],
  "domain_blacklist": [],
  "user_whitelist": [],
  "user_blacklist": [],
  "url_whitelist": [],
  "url_blacklist": [],
  "default_access_action": "allow",
  "scanner_type": "mock",
  "clamav_mode": "unix",
  "clamav_unix_socket": "/var/run/clamav/clamd.ctl",
  "clamav_host": "127.0.0.1",
  "clamav_port": 3310,
  "audit_log_path": "./logs/audit.jsonl",
  "audit_recent_limit": 500,
  "audit_max_file_size_bytes": 10485760,
  "audit_max_files": 5,
  "admin_user": "admin",
  "admin_password": "admin123",
  "enable_proxy_auth": false,
  "proxy_auth_user": "proxy",
  "proxy_auth_password": "proxy123",
  "proxy_users_file": "./configs/proxy_users.json"
}
